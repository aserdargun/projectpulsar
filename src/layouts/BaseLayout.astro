---
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import {
  SITE_URL,
  paths,
  type Language,
  type PageKey
} from "@/data/site";
import "@/styles/global.css";

interface Props {
  lang: Language;
  pageKey: PageKey;
  title: string;
  description: string;
}

const { lang, pageKey, title, description } = Astro.props;
const canonicalPath = paths[pageKey][lang];
const canonical = new URL(canonicalPath, SITE_URL);
const alternateEn = new URL(paths[pageKey].en, SITE_URL);
const alternateTr = new URL(paths[pageKey].tr, SITE_URL);
const pageTitle =
  pageKey === "home" ? "Project PULSAR" : `${title} — Project PULSAR`;
const locale = lang === "en" ? "en_US" : "tr_TR";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Project PULSAR",
    url: SITE_URL,
    inLanguage: ["en", "tr"],
    description:
      "A public vision for sovereign, trusted and adaptive AI infrastructure."
  },
  {
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    name: title,
    url: canonical.toString(),
    inLanguage: lang,
    description,
    isPartOf: {
      "@type": "WebSite",
      name: "Project PULSAR",
      url: SITE_URL
    }
  }
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#030c17" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f3f8fb" media="(prefers-color-scheme: light)" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={alternateEn} />
    <link rel="alternate" hreflang="tr" href={alternateTr} />
    <link rel="alternate" hreflang="x-default" href={alternateEn} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Project PULSAR" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={locale} />
    <meta property="og:image" content={`${SITE_URL}/social-card.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Project PULSAR — trusted intelligence, one shared runtime" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE_URL}/social-card.png`} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <script is:inline src="/theme-init.js"></script>
    <script is:inline src="/site.js" defer></script>
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">
      {lang === "en" ? "Skip to content" : "İçeriğe geç"}
    </a>
    <SiteHeader {lang} {pageKey} />
    <slot />
    <SiteFooter {lang} />
  </body>
</html>
