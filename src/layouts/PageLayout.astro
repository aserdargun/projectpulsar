---
import BaseLayout from "./BaseLayout.astro";
import CommandMap from "@/components/CommandMap.astro";
import ExperienceSections from "@/components/ExperienceSections.astro";
import InfographicGallery from "@/components/InfographicGallery.astro";
import InfrastructurePlanner from "@/components/InfrastructurePlanner.astro";
import FrontierInvestmentLab from "@/components/FrontierInvestmentLab.astro";
import ModelLab from "@/components/ModelLab.astro";
import PageVisual from "@/components/PageVisual.astro";
import { labels, paths, type Language, type PageKey } from "@/data/site";

interface Frontmatter {
  lang: Language;
  translationKey: PageKey;
  slug: string;
  title: string;
  description: string;
  navLabel: string;
  order: number;
  draft: boolean;
  eyebrow: string;
  lead: string;
}

interface Props {
  frontmatter: Frontmatter;
}

const { frontmatter } = Astro.props;
const {
  lang,
  translationKey: pageKey,
  title,
  description,
  eyebrow,
  lead
} = frontmatter;
const home = pageKey === "home";
const copy = labels[lang];
---

<BaseLayout {lang} {pageKey} {title} {description}>
  <main id="main-content">
    <section class:list={["page-hero", { "page-hero--home": home }]}>
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">{eyebrow}</p>
          <h1>{title}</h1>
          <p class="lede">{lead}</p>
          {
            home && (
              <div class="hero-actions">
                <a class="button button--primary" href={paths.infrastructure[lang]}>
                  {copy.explore}
                  <span aria-hidden="true">→</span>
                </a>
                <a class="button" href={paths.vision[lang]}>
                  {lang === "en" ? "Read the vision" : "Vizyonu oku"}
                </a>
              </div>
            )
          }
        </div>
        <div class="hero-visual">
          {home || pageKey === "platform" || pageKey === "infrastructure" ? <CommandMap {lang} /> : <PageVisual {lang} {pageKey} />}
        </div>
      </div>
      <div class="container hero-rail" aria-label={lang === "en" ? "PULSAR design principles" : "PULSAR tasarım ilkeleri"}>
        <span><i></i>{lang === "en" ? "Sovereign boundary" : "Egemen sınır"}</span>
        <span><i></i>{lang === "en" ? "Adaptive routing" : "Uyarlanan yönlendirme"}</span>
        <span><i></i>{lang === "en" ? "Permission-aware context" : "İzin farkındalıklı bağlam"}</span>
        <span><i></i>{lang === "en" ? "Human authority" : "İnsan yetkisi"}</span>
      </div>
    </section>

    <ExperienceSections {lang} {pageKey} />
    {pageKey === "infrastructure" && <InfrastructurePlanner {lang} />}
    {pageKey === "models" && <ModelLab {lang} />}
    {pageKey === "models" && <FrontierInvestmentLab {lang} />}
    <InfographicGallery {lang} {pageKey} />

    <section class="narrative-section">
      <div class="container narrative-head">
        <p class="section-label">{lang === "en" ? "Manifesto & rationale" : "Manifesto ve yaklaşım"}</p>
        <p>{lang === "en" ? "The thinking behind the system" : "Sistemin arkasındaki düşünce"}</p>
      </div>
      <div class="container content-grid">
        <article class="prose">
          <slot />
        </article>
        <aside class="principle-note surface">
          <span>{lang === "en" ? "Design invariant" : "Tasarım değişmezi"}</span>
          <strong>
            {
              lang === "en"
                ? "Intelligence may change. Trust boundaries must remain."
                : "Zekâ değişebilir. Güven sınırları kalıcı olmalıdır."
            }
          </strong>
          <small>
            {
              lang === "en"
                ? "Open research for secure, sustainable and locally operated intelligence."
                : "Güvenli, sürdürülebilir ve lokal işletilen zekâ için açık araştırma."
            }
          </small>
        </aside>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .page-hero {
    padding: 76px 0 0;
    border-bottom: 1px solid var(--line);
  }

  .page-hero--home {
    padding-top: 68px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(500px, 1.15fr);
    align-items: center;
    gap: clamp(42px, 6vw, 78px);
  }

  .hero-copy h1 {
    max-width: 820px;
    margin: 0 0 26px;
    color: var(--text);
    font-size: clamp(3.1rem, 7vw, 6.5rem);
    font-weight: 790;
    letter-spacing: -0.055em;
    line-height: 0.94;
    text-wrap: balance;
  }

  .page-hero:not(.page-hero--home) .hero-copy h1 {
    font-size: clamp(3rem, 5.4vw, 5.25rem);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 34px;
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 820px) minmax(220px, 1fr);
    align-items: start;
    gap: 70px;
    padding-top: 56px;
    padding-bottom: clamp(82px, 10vw, 130px);
  }

  .principle-note {
    position: sticky;
    top: 104px;
    padding: 22px;
  }

  .principle-note span {
    display: block;
    margin-bottom: 18px;
    color: var(--cyan);
    font-size: 0.66rem;
    font-weight: 790;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .principle-note strong {
    color: var(--text);
    font-size: 1.02rem;
    line-height: 1.4;
  }

  .principle-note small {
    display: block;
    margin-top: 20px;
    padding-top: 18px;
    border-top: 1px solid var(--line);
    color: var(--text-muted);
    font-size: 0.72rem;
    line-height: 1.5;
  }

  .hero-rail {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    margin-top: 64px;
    border-top: 1px solid var(--line);
  }

  .hero-rail span {
    display: flex;
    align-items: center;
    gap: 10px;
    min-height: 58px;
    padding: 12px 18px;
    border-right: 1px solid var(--line);
    color: var(--text-muted);
    font-size: 0.67rem;
    font-weight: 740;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .hero-rail span:first-child {
    border-left: 1px solid var(--line);
  }

  .hero-rail i {
    flex: none;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--cyan);
    box-shadow: 0 0 10px var(--cyan);
  }

  .hero-rail span:last-child i {
    background: var(--amber);
    box-shadow: 0 0 10px var(--amber);
  }

  .narrative-section {
    border-top: 1px solid var(--line);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface-muted) 42%, transparent), transparent 32rem);
  }

  .narrative-head {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    padding-top: 48px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
    color: var(--text-muted);
    font-size: 0.68rem;
    font-weight: 760;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .narrative-head p {
    margin: 0;
  }

  @media (max-width: 960px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1fr);
    }

    .hero-copy,
    .hero-visual {
      min-width: 0;
    }

    .hero-visual {
      order: 2;
    }

    .content-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .principle-note {
      position: static;
      max-width: 520px;
    }

    .hero-rail {
      grid-template-columns: repeat(2, 1fr);
    }

    .hero-rail span:nth-child(3) {
      border-left: 1px solid var(--line);
    }
  }

  @media (max-width: 600px) {
    .page-hero {
      padding-top: 52px;
    }

    .hero-grid {
      gap: 34px;
    }

    .hero-copy h1,
    .page-hero:not(.page-hero--home) .hero-copy h1 {
      font-size: clamp(2.75rem, 16vw, 4.2rem);
    }

    .hero-rail {
      margin-top: 42px;
    }

    .hero-rail span {
      min-height: 52px;
      padding: 10px;
      font-size: 0.59rem;
    }

    .narrative-head {
      align-items: flex-start;
      flex-direction: column;
      gap: 8px;
    }
  }
</style>
