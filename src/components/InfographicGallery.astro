---
import type { Language, PageKey } from "@/data/site";

interface Props {
  lang: Language;
  pageKey: PageKey;
}

const { lang, pageKey } = Astro.props;
const en = lang === "en";

const items =
  pageKey === "home"
    ? [
        {
          src: "/images/infographics/pulsar-overview.webp",
          title: en ? "PULSAR at a glance" : "PULSAR bir bakışta",
          description: en
            ? "One public-safe system view connects intent, authority, adaptive routing, permitted context, accountable outcomes, trust and evidence-led growth."
            : "Kamuya uygun tek sistem görünümü; niyeti, yetkiyi, uyarlanan yönlendirmeyi, izinli bağlamı, hesap verebilir sonucu, güveni ve kanıt odaklı büyümeyi bağlar.",
          alt: en
            ? "Project PULSAR overview infographic with five connected request stages, a central PULSAR core and three lower panels for useful work, trust and growth"
            : "Beş bağlantılı istek aşaması, merkezi PULSAR çekirdeği ve faydalı iş, güven ve büyüme için üç alt panel içeren Project PULSAR genel görünüm infografiği"
        }
      ]
    : pageKey === "platform"
      ? [
          {
            src: "/images/infographics/pulsar-request-flow.webp",
            title: en ? "The governed request path" : "Yönetişimli istek yolu",
            description: en
              ? "Eight visual stages move from intent and identity through policy, routing, context and execution to verification and an accountable outcome."
              : "Sekiz görsel aşama; niyet ve kimlikten politika, yönlendirme, bağlam ve çalıştırma üzerinden doğrulamaya ve hesap verebilir sonuca ilerler.",
            alt: en
              ? "Eight-stage Project PULSAR request flow infographic with an amber human verification gate at stage seven"
              : "Yedinci aşamada amber renkli insan doğrulama kapısı bulunan sekiz aşamalı Project PULSAR istek akışı infografiği"
          },
          {
            src: "/images/infographics/pulsar-model-paths.webp",
            title: en ? "Adaptive capability paths" : "Uyarlanan yetenek yolları",
            description: en
              ? "Fast, Medium and Frontier represent replaceable operating paths. Low confidence can trigger escalation; consequential outcomes retain human review."
              : "Fast, Medium ve Frontier değiştirilebilir çalışma yollarını temsil eder. Düşük güven yükseltmeyi tetikleyebilir; sonuç doğuran çıktılarda insan incelemesi korunur.",
            alt: en
              ? "Project PULSAR adaptive model path infographic showing Fast, Medium and Frontier routes with escalation and human review"
              : "Fast, Medium ve Frontier yollarını, yükseltmeyi ve insan incelemesini gösteren Project PULSAR uyarlanan model yolu infografiği"
          }
        ]
      : [];

const heading =
  pageKey === "home"
    ? en
      ? "The vision, in one system view"
      : "Vizyon, tek sistem görünümünde"
    : en
      ? "Architecture, made visible"
      : "Görünür kılınan mimari";
---

{
  items.length > 0 && (
    <section class="infographic-section" aria-labelledby={`infographics-${pageKey}`}>
      <div class="container">
        <div class="infographic-head">
          <div>
            <p>{en ? "Public vision graphics" : "Kamusal vizyon grafikleri"}</p>
            <h2 id={`infographics-${pageKey}`}>{heading}</h2>
          </div>
          <span>{en ? "No company attribution · no internal system detail" : "Kurum atfı yok · iç sistem ayrıntısı yok"}</span>
        </div>

        <div class:list={["infographic-grid", { "infographic-grid--single": items.length === 1 }]}>
          {items.map((item) => (
            <figure class="infographic-card">
              <a
                class="infographic-image"
                href={item.src}
                target="_blank"
                rel="noopener"
                aria-label={`${item.title} — ${en ? "open full-size image" : "tam boy görseli aç"}`}
              >
                <img
                  src={item.src}
                  alt={item.alt}
                  width="1672"
                  height="941"
                  loading="lazy"
                  decoding="async"
                />
                <span>{en ? "Open full size" : "Tam boy aç"} ↗</span>
              </a>
              <figcaption>
                <h3>{item.title}</h3>
                <p>{item.description}</p>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  .infographic-section {
    padding-block: clamp(72px, 9vw, 118px);
    border-block: 1px solid var(--line);
    background:
      radial-gradient(circle at 50% 10%, var(--glow), transparent 34rem),
      color-mix(in srgb, var(--surface-muted) 56%, transparent);
  }

  .infographic-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    gap: 40px;
    margin-bottom: 34px;
  }

  .infographic-head p {
    margin: 0 0 13px;
    color: var(--cyan);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .infographic-head h2 {
    max-width: 820px;
    margin: 0;
    color: var(--text);
    font-size: clamp(2rem, 4vw, 3.8rem);
    letter-spacing: -0.045em;
    line-height: 0.98;
    text-wrap: balance;
  }

  .infographic-head > span {
    max-width: 280px;
    padding: 8px 11px;
    border: 1px solid color-mix(in srgb, var(--amber) 44%, var(--line));
    border-radius: 999px;
    color: var(--amber);
    font-size: 0.62rem;
    font-weight: 760;
    letter-spacing: 0.06em;
    text-align: center;
    text-transform: uppercase;
  }

  .infographic-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .infographic-grid--single {
    grid-template-columns: 1fr;
  }

  .infographic-card {
    margin: 0;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--bg-elevated);
    box-shadow: var(--shadow);
  }

  .infographic-image {
    position: relative;
    display: block;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
    background: #020a16;
  }

  .infographic-image img {
    width: 100%;
    height: auto;
    transition: transform 320ms ease;
  }

  .infographic-image span {
    position: absolute;
    right: 13px;
    bottom: 13px;
    padding: 7px 10px;
    border: 1px solid rgba(103, 226, 246, 0.34);
    border-radius: 999px;
    background: rgba(2, 12, 23, 0.8);
    color: #aef5ff;
    font-size: 0.61rem;
    font-weight: 760;
    letter-spacing: 0.06em;
    opacity: 0;
    transform: translateY(5px);
    transition:
      opacity 160ms ease,
      transform 160ms ease;
  }

  .infographic-image:hover img {
    transform: scale(1.012);
  }

  .infographic-image:hover span,
  .infographic-image:focus-visible span {
    opacity: 1;
    transform: translateY(0);
  }

  figcaption {
    min-height: 155px;
    padding: 22px 24px 25px;
  }

  figcaption h3 {
    margin: 0 0 10px;
    color: var(--text);
    font-size: 1.12rem;
  }

  figcaption p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.82rem;
    line-height: 1.55;
  }

  .infographic-grid--single .infographic-card {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(270px, 0.4fr);
    align-items: stretch;
  }

  .infographic-grid--single .infographic-image {
    border-right: 1px solid var(--line);
    border-bottom: 0;
  }

  .infographic-grid--single figcaption {
    display: grid;
    align-content: center;
    min-height: 0;
    padding: clamp(25px, 4vw, 48px);
  }

  @media (max-width: 860px) {
    .infographic-head,
    .infographic-grid,
    .infographic-grid--single,
    .infographic-grid--single .infographic-card {
      grid-template-columns: 1fr;
    }

    .infographic-head {
      align-items: start;
      gap: 20px;
    }

    .infographic-head > span {
      justify-self: start;
    }

    .infographic-grid--single .infographic-image {
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }
  }

  @media (max-width: 520px) {
    .infographic-section {
      padding-block: 64px;
    }

    figcaption {
      min-height: 0;
      padding: 20px;
    }

    .infographic-image span {
      display: none;
    }
  }
</style>
