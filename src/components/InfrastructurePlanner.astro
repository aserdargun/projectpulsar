---
import {
  CalendarClock,
  Calculator,
  Database,
  Gauge,
  HardDrive,
  Leaf,
  Network,
  Router,
  Server,
  ShieldCheck
} from "@lucide/astro";
import type { Language } from "@/data/site";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const en = lang === "en";
const asOfIso = "2026-07-20";
const asOf = en ? "20 July 2026" : "20 Temmuz 2026";
const usdTry = 47.1787;

const assumptions = {
  freight: 3,
  duty: 0,
  clearance: 1.5,
  vat: 20
};

const scenarios = en
  ? [
      {
        id: "lab",
        code: "R01",
        name: "Research node",
        intent: "Evaluation, retrieval, fine-tuning experiments and controlled team use",
        gpu: "2 × 96 GB server/workstation accelerators",
        memory: "192 GB accelerator · 512 GB ECC system",
        storage: "8 TB NVMe · protected model registry",
        network: "25–100 GbE · isolated management",
        power: "1.5–2.0 kW design envelope",
        fit: "Quantized 70B-class models, smaller dense models, embeddings and rerankers",
        cost: 50000
      },
      {
        id: "production",
        code: "R02",
        name: "Production core",
        intent: "Shared inference, higher concurrency, governed tools and service resilience",
        gpu: "4 × 96 GB server accelerators",
        memory: "384 GB accelerator · 1 TB ECC system",
        storage: "15 TB NVMe · replicated artifact store",
        network: "Dual 100 GbE · redundant service path",
        power: "3.5–4.5 kW design envelope",
        fit: "70B-class models at higher concurrency, moderate MoE paths and parallel services",
        cost: 110000,
        recommended: true
      },
      {
        id: "scale",
        code: "R03",
        name: "Shared research cluster",
        intent: "Multiple model services, large-context research and capacity expansion",
        gpu: "8 × 96 GB server accelerators",
        memory: "768 GB accelerator · 2 TB ECC system",
        storage: "30 TB NVMe · durable shared object storage",
        network: "Dual 100/200 GbE · separate storage fabric",
        power: "7–9 kW design envelope",
        fit: "Larger MoE experiments, multiple resident models and bounded multi-team service",
        cost: 220000
      }
    ]
  : [
      {
        id: "lab",
        code: "R01",
        name: "Araştırma sunucusu",
        intent: "Değerlendirme, bilgi erişimi, ince ayar deneyleri ve kontrollü ekip kullanımı",
        gpu: "2 × 96 GB sunucu/iş istasyonu hızlandırıcısı",
        memory: "192 GB hızlandırıcı · 512 GB ECC sistem",
        storage: "8 TB NVMe · korumalı model kayıt alanı",
        network: "25–100 GbE · izole yönetim ağı",
        power: "1,5–2,0 kW tasarım zarfı",
        fit: "Nicemlenmiş 70B sınıfı modeller, daha küçük yoğun modeller, embedding ve reranker",
        cost: 50000
      },
      {
        id: "production",
        code: "R02",
        name: "Üretim çekirdeği",
        intent: "Paylaşımlı çıkarım, yüksek eşzamanlılık, yönetişimli araçlar ve hizmet dayanıklılığı",
        gpu: "4 × 96 GB sunucu hızlandırıcısı",
        memory: "384 GB hızlandırıcı · 1 TB ECC sistem",
        storage: "15 TB NVMe · çoğaltılmış model deposu",
        network: "Çift 100 GbE · yedekli hizmet yolu",
        power: "3,5–4,5 kW tasarım zarfı",
        fit: "Yüksek eşzamanlı 70B sınıfı modeller, orta ölçekli MoE yolları ve paralel servisler",
        cost: 110000,
        recommended: true
      },
      {
        id: "scale",
        code: "R03",
        name: "Paylaşımlı araştırma kümesi",
        intent: "Birden fazla model servisi, geniş bağlam araştırması ve kapasite büyütme",
        gpu: "8 × 96 GB sunucu hızlandırıcısı",
        memory: "768 GB hızlandırıcı · 2 TB ECC sistem",
        storage: "30 TB NVMe · dayanıklı paylaşımlı nesne depolama",
        network: "Çift 100/200 GbE · ayrı depolama ağı",
        power: "7–9 kW tasarım zarfı",
        fit: "Daha büyük MoE deneyleri, eşzamanlı modeller ve sınırlı çok ekipli hizmet",
        cost: 220000
      }
    ];

const architecture = en
  ? [
      ["01", "Access & governance", "Identity, purpose, policy, quota and approval enter before model execution.", ShieldCheck],
      ["02", "PULSAR control plane", "Gateway, router, model registry, evaluation gates and release policy stay separate from models.", Router],
      ["03", "Permitted data plane", "Retrieval, object storage and tools inherit source authority and remain network-bounded.", Database],
      ["04", "Inference plane", "Open-weight models run in isolated pools with quantization, batching and task-aware routing.", Server],
      ["05", "Evidence & operations", "Tracing, quality evaluation, power telemetry and human review shape every release.", Gauge]
    ]
  : [
      ["01", "Erişim ve yönetişim", "Kimlik, amaç, politika, kota ve onay model çalışmadan önce akışa girer.", ShieldCheck],
      ["02", "PULSAR kontrol düzlemi", "Gateway, router, model kaydı, değerlendirme kapıları ve sürüm politikası modellerden ayrılır.", Router],
      ["03", "İzinli veri düzlemi", "Bilgi erişimi, nesne depolama ve araçlar kaynak yetkisini devralır; ağ sınırında kalır.", Database],
      ["04", "Çıkarım düzlemi", "Açık-ağırlık modeller; izolasyon, nicemleme, batching ve görev odaklı yönlendirmeyle çalışır.", Server],
      ["05", "Kanıt ve işletme", "İz kaydı, kalite değerlendirmesi, enerji telemetrisi ve insan incelemesi her sürümü şekillendirir.", Gauge]
    ];

const formatUsd = (value: number) =>
  new Intl.NumberFormat(en ? "en-US" : "tr-TR", {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: 0
  }).format(value);

const formatTry = (value: number) =>
  new Intl.NumberFormat(en ? "en-US" : "tr-TR", {
    style: "currency",
    currency: "TRY",
    maximumFractionDigits: 0
  }).format(value);

const landed = (base: number) => {
  const cif = base * (1 + assumptions.freight / 100);
  const duty = cif * (assumptions.duty / 100);
  const clearance = cif * (assumptions.clearance / 100);
  const importVat = (cif + duty) * (assumptions.vat / 100);
  const net = cif + duty + clearance;
  const gross = net + importVat;
  return { cif, duty, clearance, importVat, net, gross };
};

const initial = landed(scenarios[1].cost);
---

{
  lang && (
    <div class="infrastructure-planner">
      <section class="architecture-section container" aria-labelledby="reference-architecture">
        <div class="section-head">
          <div>
            <p class="section-index">{en ? "01 / Reference architecture" : "01 / Referans mimari"}</p>
            <h2 id="reference-architecture">
              {en ? "Local by default. Open at the model boundary." : "Varsayılan olarak lokal. Model sınırında açık."}
            </h2>
          </div>
          <p>
            {en
              ? "The durable system is not the GPU server alone. It is the governed path around models, data and human authority."
              : "Kalıcı sistem yalnız GPU sunucusu değildir. Modellerin, verinin ve insan yetkisinin çevresindeki yönetişimli yoldur."}
          </p>
        </div>

        <div class="architecture-board">
          <div class="architecture-flow">
            {architecture.map(([number, title, description, Icon]) => (
              <article>
                <span>{number}</span>
                <Icon size={23} stroke-width={1.55} aria-hidden="true" />
                <div>
                  <h3>{title}</h3>
                  <p>{description}</p>
                </div>
              </article>
            ))}
          </div>
          <aside class="design-rails">
            <span>{en ? "NON-NEGOTIABLE RAILS" : "VAZGEÇİLMEZ SINIRLAR"}</span>
            <ul>
              <li>{en ? "No direct user-to-model path" : "Doğrudan kullanıcı-model yolu yok"}</li>
              <li>{en ? "No unrestricted model egress" : "Sınırsız model dış ağ erişimi yok"}</li>
              <li>{en ? "Signed and scanned model artifacts" : "İmzalı ve taranmış model dosyaları"}</li>
              <li>{en ? "Read-only tools before write authority" : "Yazma yetkisinden önce salt okunur araçlar"}</li>
              <li>{en ? "Evaluation gate before every release" : "Her sürümden önce değerlendirme kapısı"}</li>
              <li>{en ? "Human authority for consequential action" : "Sonuç doğuran eylemde insan yetkisi"}</li>
            </ul>
          </aside>
        </div>
      </section>

      <section class="scenario-section">
        <div class="container">
          <div class="section-head">
            <div>
              <p class="section-index">{en ? "02 / Capacity scenarios" : "02 / Kapasite senaryoları"}</p>
              <h2>{en ? "Start with a workload envelope—not a shopping list" : "Alışveriş listesiyle değil, iş yükü zarfıyla başla"}</h2>
            </div>
            <p>
              {en
                ? "Memory fit depends on model architecture, precision, context length, concurrency and serving software. Benchmark before purchase."
                : "Bellek uyumu; model mimarisi, hassasiyet, bağlam uzunluğu, eşzamanlılık ve servis yazılımına bağlıdır. Satın almadan önce benchmark yapın."}
            </p>
          </div>

          <div class="scenario-grid">
            {scenarios.map((scenario) => (
              <article class:list={["scenario-card", { "scenario-card--recommended": scenario.recommended }]}>
                <div class="scenario-top">
                  <span>{scenario.code}</span>
                  {scenario.recommended && <strong>{en ? "REFERENCE START" : "REFERANS BAŞLANGIÇ"}</strong>}
                </div>
                <h3>{scenario.name}</h3>
                <p class="scenario-intent">{scenario.intent}</p>
                <dl>
                  <div><dt>{en ? "Compute" : "Hesaplama"}</dt><dd>{scenario.gpu}</dd></div>
                  <div><dt>{en ? "Memory" : "Bellek"}</dt><dd>{scenario.memory}</dd></div>
                  <div><dt>{en ? "Storage" : "Depolama"}</dt><dd>{scenario.storage}</dd></div>
                  <div><dt>{en ? "Network" : "Ağ"}</dt><dd>{scenario.network}</dd></div>
                  <div><dt>{en ? "Facility" : "Tesis"}</dt><dd>{scenario.power}</dd></div>
                </dl>
                <div class="model-fit"><HardDrive size={17} aria-hidden="true" /><span>{scenario.fit}</span></div>
                <div class="scenario-cost">
                  <span>{en ? "REFERENCE CAPEX" : "REFERANS CAPEX"}</span>
                  <strong>{formatUsd(scenario.cost)}</strong>
                </div>
              </article>
            ))}
          </div>

          <div class="capacity-note">
            <Network size={20} aria-hidden="true" />
            <p>
              {en
                ? "Reference prices include accelerator hardware, host platform, ECC memory, NVMe storage, network/security components and an integration contingency. They are planning estimates—not vendor quotes."
                : "Referans fiyatlar; hızlandırıcı donanımı, sunucu platformu, ECC bellek, NVMe depolama, ağ/güvenlik bileşenleri ve entegrasyon payını içerir. Bunlar tedarikçi teklifi değil, planlama tahminidir."}
            </p>
          </div>
        </div>
      </section>

      <section class="cost-section container" aria-labelledby="cost-calculator">
        <div class="section-head">
          <div>
            <p class="section-index">{en ? "03 / Türkiye landed cost" : "03 / Türkiye ithalat maliyeti"}</p>
            <h2 id="cost-calculator">{en ? "Make the assumptions visible" : "Varsayımları görünür kıl"}</h2>
          </div>
          <div class="date-stamp">
            <CalendarClock size={20} aria-hidden="true" />
            <span>
              {en ? "Calculation date" : "Hesap tarihi"}
              <strong><time datetime={asOfIso}>{asOf}</time></strong>
            </span>
          </div>
        </div>

        <div
          class="calculator-board"
          data-cost-calculator
          data-lang={lang}
          data-default-rate={usdTry}
        >
          <form class="calculator-inputs">
            <div class="calculator-title">
              <Calculator size={24} aria-hidden="true" />
              <div>
                <h3>{en ? "Planning calculator" : "Planlama hesaplayıcısı"}</h3>
                <p>{en ? "Edit every rate before a procurement decision." : "Tedarik kararından önce her oranı güncelleyin."}</p>
              </div>
            </div>

            <label>
              <span>{en ? "Reference system" : "Referans sistem"}</span>
              <select data-field="scenario">
                {scenarios.map((scenario) => (
                  <option value={scenario.cost} selected={scenario.recommended}>
                    {scenario.name} — {formatUsd(scenario.cost)}
                  </option>
                ))}
              </select>
            </label>

            <div class="field-grid">
              <label>
                <span>USD/TRY</span>
                <input data-field="fx" type="number" min="0" step="0.0001" value={usdTry} />
              </label>
              <label>
                <span>{en ? "Freight & insurance" : "Navlun ve sigorta"} (%)</span>
                <input data-field="freight" type="number" min="0" step="0.1" value={assumptions.freight} />
              </label>
              <label>
                <span>{en ? "Customs duty" : "Gümrük vergisi"} (%)</span>
                <input data-field="duty" type="number" min="0" step="0.1" value={assumptions.duty} />
              </label>
              <label>
                <span>{en ? "Clearance allowance" : "Gümrükleme payı"} (%)</span>
                <input data-field="clearance" type="number" min="0" step="0.1" value={assumptions.clearance} />
              </label>
              <label>
                <span>{en ? "Import VAT" : "İthalat KDV"} (%)</span>
                <input data-field="vat" type="number" min="0" step="0.1" value={assumptions.vat} />
              </label>
            </div>
          </form>

          <div class="calculator-results" aria-live="polite">
            <div><span>{en ? "Base system" : "Sistem bedeli"}</span><strong data-result="base">{formatUsd(scenarios[1].cost)}</strong></div>
            <div><span>CIF</span><strong data-result="cif">{formatUsd(initial.cif)}</strong></div>
            <div><span>{en ? "Customs duty" : "Gümrük vergisi"}</span><strong data-result="duty">{formatUsd(initial.duty)}</strong></div>
            <div><span>{en ? "Import VAT" : "İthalat KDV"}</span><strong data-result="vat">{formatUsd(initial.importVat)}</strong></div>
            <div class="result-major"><span>{en ? "Net landed cost, VAT excluded" : "KDV hariç net ithalat maliyeti"}</span><strong data-result="net-usd">{formatUsd(initial.net)}</strong><small data-result="net-try">{formatTry(initial.net * usdTry)}</small></div>
            <div class="result-major result-major--gross"><span>{en ? "Gross cash outlay, VAT included" : "KDV dahil brüt nakit çıkışı"}</span><strong data-result="gross-usd">{formatUsd(initial.gross)}</strong><small data-result="gross-try">{formatTry(initial.gross * usdTry)}</small></div>
          </div>
        </div>

        <div class="assumption-grid">
          <article>
            <span>{en ? "CUSTOMS" : "GÜMRÜK"}</span>
            <h3>{en ? "0% is a planning default—not a tariff ruling" : "%0 bir planlama varsayımıdır; tarife kararı değildir"}</h3>
            <p>
              {en
                ? "Confirm GTIP classification, origin, trade regime, Incoterm and any additional duty with a licensed customs broker before ordering."
                : "Siparişten önce GTİP sınıflandırmasını, menşei, ticaret rejimini, Incoterm'ü ve olası ilave vergiyi yetkili gümrük müşaviriyle doğrulayın."}
            </p>
          </article>
          <article>
            <span>{en ? "VAT" : "KDV"}</span>
            <h3>{en ? "Cash outlay and economic cost are different views" : "Nakit çıkışı ile ekonomik maliyet farklı görünümlerdir"}</h3>
            <p>
              {en
                ? "Import VAT is shown in gross cash outlay. Whether it is recoverable depends on the taxpayer and use; obtain tax advice."
                : "İthalat KDV'si brüt nakit çıkışında gösterilir. İndirilebilirliği mükellef ve kullanım durumuna bağlıdır; vergi danışmanlığı alın."}
            </p>
          </article>
          <article>
            <span>{en ? "REFRESH" : "GÜNCELLEME"}</span>
            <h3>{en ? "Update the calculation date at least monthly" : "Hesap tarihini en az ayda bir güncelleyin"}</h3>
            <p>
              {en
                ? "Refresh accelerator prices, supplier quote, TCMB selling rate, freight, tariff and VAT—and always recalculate on the customs declaration date."
                : "Hızlandırıcı fiyatını, tedarikçi teklifini, TCMB satış kurunu, navlunu, tarifeyi ve KDV'yi yenileyin; gümrük beyannamesi tarihinde mutlaka yeniden hesaplayın."}
            </p>
          </article>
        </div>
      </section>

      <section class="sustainability-section">
        <div class="container sustainability-board">
          <div>
            <p class="section-index">{en ? "04 / Sustainable operation" : "04 / Sürdürülebilir işletme"}</p>
            <h2>{en ? "Useful intelligence per unit of energy" : "Enerji başına faydalı zekâ"}</h2>
            <p>
              {en
                ? "Sustainability begins with routing and measurement—not a larger server."
                : "Sürdürülebilirlik daha büyük bir sunucuyla değil, yönlendirme ve ölçümle başlar."}
            </p>
          </div>
          <div class="sustainability-grid">
            <article><Leaf size={22} aria-hidden="true" /><h3>{en ? "Right-size models" : "Modeli doğru boyutlandır"}</h3><p>{en ? "Prefer the smallest path that meets the evaluated quality threshold." : "Değerlendirilmiş kalite eşiğini karşılayan en küçük yolu tercih et."}</p></article>
            <article><Gauge size={22} aria-hidden="true" /><h3>{en ? "Measure real work" : "Gerçek işi ölç"}</h3><p>{en ? "Track energy, utilization, queue time and accepted output by workload." : "Enerji, kullanım, kuyruk süresi ve kabul edilen çıktıyı iş yükü bazında izle."}</p></article>
            <article><Server size={22} aria-hidden="true" /><h3>{en ? "Share capacity safely" : "Kapasiteyi güvenle paylaş"}</h3><p>{en ? "Use batching, quotas and isolated pools before adding hardware." : "Donanım eklemeden önce batching, kota ve izole havuzlar kullan."}</p></article>
          </div>
        </div>
      </section>

      <section class="source-section container">
        <p class="section-index">{en ? "Sources & method" : "Kaynaklar ve yöntem"}</p>
        <div class="source-grid">
          <a href="https://www.nvidia.com/en-us/data-center/rtx-pro-6000-blackwell-server-edition/" rel="external">
            <strong>{en ? "Accelerator specification" : "Hızlandırıcı teknik özellikleri"}</strong>
            <span>NVIDIA · 96 GB server edition</span>
          </a>
          <a href="https://marketplace.nvidia.com/en-us/enterprise/laptops-workstations/nvidia-rtx-pro-6000-blackwell-workstation-edition/" rel="external">
            <strong>{en ? "Public price proxy" : "Kamusal fiyat göstergesi"}</strong>
            <span>{en ? "NVIDIA workstation edition" : "NVIDIA iş istasyonu sürümü"} · {formatUsd(13250)}</span>
          </a>
          <a href="https://docs.nvidia.com/enterprise-reference-architectures/rtx-pro-ai-factory/latest/components.html" rel="external">
            <strong>{en ? "Server architecture envelope" : "Sunucu mimarisi zarfı"}</strong>
            <span>NVIDIA · up to 8 × 96 GB</span>
          </a>
          <a href="https://www.tcmb.gov.tr/kurlar/202607/20072026.xml" rel="external">
            <strong>{en ? "USD/TRY selling rate" : "USD/TRY döviz satış kuru"}</strong>
            <span>TCMB · {usdTry} · {asOf}</span>
          </a>
          <a href="https://ticaret.gov.tr/gumruk-islemleri/sikca-sorulan-sorular/ticari/gumruk-kiymeti" rel="external">
            <strong>{en ? "Customs value and FX method" : "Gümrük kıymeti ve kur yöntemi"}</strong>
            <span>{en ? "Ministry of Trade" : "T.C. Ticaret Bakanlığı"}</span>
          </a>
          <a href="https://cdn.gib.gov.tr/api/gibportal-file/file/getFileResources?objectKey=arsiv%2Fyardim-kaynaklar%2Fyararli-bilgiler%2Fkdv-oranlari.pdf" rel="external">
            <strong>{en ? "General VAT rate" : "Genel KDV oranı"}</strong>
            <span>{en ? "Revenue Administration · 20%" : "Gelir İdaresi Başkanlığı · %20"}</span>
          </a>
        </div>
        <p class="method-note">
          {en
            ? "Method: reference CapEx × freight/insurance = CIF; customs duty is applied to CIF; import VAT is applied to CIF plus duty; the clearance allowance is added separately. This simplified public model excludes financing, KKDF, local reseller margin, building works, electricity and recoverability timing."
            : "Yöntem: referans CapEx × navlun/sigorta = CIF; gümrük vergisi CIF üzerine, ithalat KDV'si CIF + vergi üzerine uygulanır; gümrükleme payı ayrıca eklenir. Bu sadeleştirilmiş kamusal model; finansman, KKDF, yerel satıcı marjı, bina işleri, elektrik ve KDV indirim zamanlamasını kapsamaz."}
        </p>
      </section>
    </div>
  )
}

<script>
  const calculators = document.querySelectorAll<HTMLElement>("[data-cost-calculator]");

  const currency = (locale: string, code: "USD" | "TRY", value: number) =>
    new Intl.NumberFormat(locale, {
      style: "currency",
      currency: code,
      maximumFractionDigits: 0
    }).format(value);

  calculators.forEach((calculator) => {
    const locale = calculator.dataset.lang === "tr" ? "tr-TR" : "en-US";
    const field = (name: string) =>
      calculator.querySelector<HTMLInputElement | HTMLSelectElement>(`[data-field="${name}"]`);
    const result = (name: string) =>
      calculator.querySelector<HTMLElement>(`[data-result="${name}"]`);

    const update = () => {
      const base = Number(field("scenario")?.value ?? 0);
      const fx = Number(field("fx")?.value ?? 0);
      const freightRate = Number(field("freight")?.value ?? 0) / 100;
      const dutyRate = Number(field("duty")?.value ?? 0) / 100;
      const clearanceRate = Number(field("clearance")?.value ?? 0) / 100;
      const vatRate = Number(field("vat")?.value ?? 0) / 100;

      const cif = base * (1 + freightRate);
      const duty = cif * dutyRate;
      const clearance = cif * clearanceRate;
      const vat = (cif + duty) * vatRate;
      const net = cif + duty + clearance;
      const gross = net + vat;

      const values: Record<string, string> = {
        base: currency(locale, "USD", base),
        cif: currency(locale, "USD", cif),
        duty: currency(locale, "USD", duty),
        vat: currency(locale, "USD", vat),
        "net-usd": currency(locale, "USD", net),
        "gross-usd": currency(locale, "USD", gross),
        "net-try": currency(locale, "TRY", net * fx),
        "gross-try": currency(locale, "TRY", gross * fx)
      };

      Object.entries(values).forEach(([key, value]) => {
        const node = result(key);
        if (node) node.textContent = value;
      });
    };

    calculator.querySelectorAll("input, select").forEach((input) => {
      input.addEventListener("input", update);
      input.addEventListener("change", update);
    });
  });
</script>

<style>
  .infrastructure-planner {
    --infra-radius: 10px;
  }

  .architecture-section,
  .scenario-section,
  .cost-section,
  .sustainability-section,
  .source-section {
