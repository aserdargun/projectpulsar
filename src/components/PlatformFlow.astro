---
import type { Language } from "@/data/site";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const steps =
  lang === "en"
    ? [
        ["01", "Intent", "A person, application or agent asks for help."],
        ["02", "Trust", "Identity, permission and policy are evaluated."],
        ["03", "Route", "The smallest capable model path is selected."],
        ["04", "Ground", "Only permitted context and tools are introduced."],
        ["05", "Verify", "Evidence, controls and human authority shape the result."]
      ]
    : [
        ["01", "Niyet", "Bir kişi, uygulama veya agent yardım ister."],
        ["02", "Güven", "Kimlik, yetki ve politika değerlendirilir."],
        ["03", "Yönlendir", "Yeterli olan en küçük model yolu seçilir."],
        ["04", "Bağlamlandır", "Yalnız izinli bağlam ve araçlar eklenir."],
        ["05", "Doğrula", "Kanıt, kontroller ve insan yetkisi sonucu şekillendirir."]
      ];
---

<section class="flow" aria-labelledby="flow-title">
  <div class="flow-heading">
    <p class="eyebrow">{lang === "en" ? "One governed path" : "Tek ve kontrollü akış"}</p>
    <h2 id="flow-title">{lang === "en" ? "From intent to accountable outcome" : "Niyetten hesap verebilir sonuca"}</h2>
  </div>
  <ol>
    {
      steps.map(([index, title, description]) => (
        <li>
          <span class="index">{index}</span>
          <strong>{title}</strong>
          <p>{description}</p>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .flow {
    margin-top: 90px;
  }

  .flow-heading {
    max-width: 680px;
    margin-bottom: 30px;
  }

  h2 {
    margin: 0;
    color: var(--text);
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.08;
    text-wrap: balance;
  }

  ol {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    margin: 0;
    padding: 0;
    list-style: none;
    gap: 12px;
  }

  li {
    position: relative;
    min-height: 216px;
    padding: 22px 19px;
    border: 1px solid var(--line);
    border-radius: 20px;
    background: var(--bg-elevated);
  }

  li:not(:last-child)::after {
    position: absolute;
    z-index: 2;
    top: 50%;
    right: -17px;
    width: 21px;
    height: 1px;
    background: var(--cyan);
    content: "";
  }

  .index {
    display: block;
    margin-bottom: 32px;
    color: var(--cyan);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.12em;
  }

  strong {
    color: var(--text);
    font-size: 1.08rem;
  }

  p {
    margin: 10px 0 0;
    color: var(--text-muted);
    font-size: 0.86rem;
    line-height: 1.55;
  }

  @media (max-width: 960px) {
    ol {
      grid-template-columns: repeat(2, 1fr);
    }

    li:last-child {
      grid-column: 1 / -1;
    }

    li::after {
      display: none;
    }
  }

  @media (max-width: 560px) {
    ol {
      grid-template-columns: 1fr;
    }

    li:last-child {
      grid-column: auto;
    }
  }
</style>
